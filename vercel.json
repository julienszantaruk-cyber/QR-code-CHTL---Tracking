{
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/create", "dest": "/api/create.py" },
    { "src": "/api/delete/(.*)", "dest": "/api/delete.py?id=$1" },
    { "src": "/api/stats", "dest": "/api/stats.py" },
    { "src": "/api/login", "dest": "/api/login.py" },
    { "src": "/api/logout", "dest": "/api/logout.py" },
    { "src": "/s/(.*)", "dest": "/api/scan.py?id=$1" },
    { "src": "/(.*)", "dest": "/api/index.py" }
  ]
}
